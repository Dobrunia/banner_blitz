{
  "name": "flag-quiz",
  "version": "0.2.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc --noEmit && vite build",
    "preview": "vite preview",
    "test": "vitest",
    "typecheck": "vue-tsc --noEmit",
    "download-flags": "node scripts/download-flags.js",
    "build:paintings": "node scripts/build-met-paintings.mjs",
    "sync:paintings": "node scripts/sync-painting-images.mjs",
    "validate:paintings": "node scripts/validate-paintings-bundle.mjs",
    "cap:copy": "npx cap copy",
    "cap:sync": "npx cap sync",
    "cap:open:android": "npx cap open android",
    "cap:open:ios": "npx cap open ios",
    "cap:build:android": "npm run build && npx cap copy && npx cap open android",
    "cap:build:ios": "npm run build && npx cap copy && npx cap open ios",
    "cap:apk": "npm run build && npx cap copy && cd android && gradlew.bat assembleDebug",
    "build:apk": "npm run build && npx cap copy && cd android && gradlew.bat assembleDebug && copy app\\build\\outputs\\apk\\debug\\app-debug.apk ..\\apk-builds\\latest.apk"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^6.0.7",
    "@vitest/coverage-v8": "^4.1.7",
    "@vue/test-utils": "^2.4.10",
    "jsdom": "^29.1.1",
    "typescript": "^6.0.3",
    "vite": "^7.1.7",
    "vite-plugin-pwa": "^1.0.3",
    "vitest": "^4.1.7",
    "vue-tsc": "^3.3.1"
  },
  "dependencies": {
    "@capacitor/android": "^7.4.3",
    "@capacitor/cli": "^7.4.3",
    "@capacitor/core": "^7.4.3",
    "@capacitor/ios": "^7.4.3",
    "is-core-module": "^2.16.1",
    "vue": "^3.5.34"
  }
}
